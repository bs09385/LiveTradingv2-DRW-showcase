<Window x:Class="PolymarketUI.Views.LadderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PolymarketUI.Views"
        Title="{Binding SeriesKey, StringFormat='BTC Ladder - {0}'}"
        Height="850" Width="480"
        MinHeight="400" MinWidth="350"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip">
    <views:LadderView DataContext="{Binding}"/>
</Window>
