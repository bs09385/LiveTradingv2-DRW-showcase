<UserControl x:Class="PolymarketUI.Views.PositionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="200" d:DesignWidth="400">
    <Border BorderBrush="Gray" BorderThickness="1" Margin="4" Padding="4">
        <StackPanel>
            <TextBlock Text="Positions" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
            <DataGrid ItemsSource="{Binding Positions}" Height="180" FontSize="13" ColumnWidth="*"
                      PreviewMouseWheel="DataGrid_PreviewMouseWheel">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Market" Binding="{Binding ConditionId}" Width="*"/>
                    <DataGridTextColumn Header="Pos Up" Binding="{Binding PositionUpStr}" Width="*"/>
                    <DataGridTextColumn Header="Pos Down" Binding="{Binding PositionDownStr}" Width="*"/>
                    <DataGridTextColumn Header="Net" Binding="{Binding NetExposureStr}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Border>
</UserControl>
