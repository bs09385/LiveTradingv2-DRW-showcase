<UserControl x:Class="PolymarketUI.Views.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PolymarketUI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="260" d:DesignWidth="350">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToColorConverter x:Key="StrategyIndicator" TrueBrush="#2E7D32" FalseBrush="#C62828"/>
        <conv:InverseBoolToColorConverter x:Key="LiveIndicator" TrueBrush="#C62828" FalseBrush="#2E7D32"/>
    </UserControl.Resources>
    <Border BorderBrush="Gray" BorderThickness="1" Margin="4" Padding="6">
        <StackPanel>
            <TextBlock Text="Control Panel" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

            <!-- Strategy Toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <Button Content="{Binding StrategyToggleText}" Command="{Binding ToggleStrategyCommand}"
                        Width="50" Height="26" Margin="0,0,8,0" FontWeight="Bold"/>
                <TextBlock Text="Strategy:" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                         Fill="{Binding StrategyEnabled, Converter={StaticResource StrategyIndicator}}"/>
            </StackPanel>

            <!-- Mode Toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,6">
                <Button Content="{Binding ModeToggleText}" Command="{Binding ToggleModeCommand}"
                        Width="50" Height="26" Margin="0,0,8,0" FontWeight="Bold"/>
                <TextBlock Text="Live:" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                         Fill="{Binding IsDryRun, Converter={StaticResource LiveIndicator}}"/>
            </StackPanel>

            <Separator Margin="0,6"/>

            <!-- Cancel All + Probe -->
            <StackPanel Orientation="Horizontal" Margin="0,6">
                <Button Content="Cancel All" Command="{Binding CancelAllCommand}"
                        Width="100" Height="28" Background="#C62828" Foreground="White" FontWeight="Bold"/>
                <Button Content="Probe Latency" Command="{Binding ProbeLatencyCommand}"
                        IsEnabled="{Binding IsProbeAllowed}"
                        Width="110" Height="28" Background="#1565C0" Foreground="White"
                        FontWeight="Bold" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Emergency Sell Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <Button Content="Sell UP" Command="{Binding MarketSellAllCommand}"
                        Width="80" Background="#FF4444" Foreground="White" FontWeight="Bold"/>
                <Button Content="Sell DOWN" Command="{Binding MarketSellDownCommand}"
                        Width="95" Background="#FF4444" Foreground="White" FontWeight="Bold" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Session Status -->
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="Session:" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Width="80"/>
                <TextBlock Text="{Binding SessionStatusText}" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Separator Margin="0,6"/>

            <!-- Session (IDLE) -->
            <StackPanel Visibility="{Binding IsSessionIdle, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Button Content="Start Session" Command="{Binding StartSessionCommand}"
                            Background="#2E7D32" Foreground="White" FontWeight="Bold"
                            Width="110" Height="28" Margin="0,0,10,0"/>
                    <CheckBox Content="Indefinite" IsChecked="{Binding IsIndefinite}"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="End:" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding EndTimeText, UpdateSourceTrigger=PropertyChanged}" Width="52"
                             FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                             IsEnabled="{Binding IsNotIndefinite}"/>
                    <TextBlock Text="UTC" FontFamily="Consolas" FontSize="10" Foreground="#888"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Session (ACTIVE) -->
            <StackPanel Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Button Content="Stop Session" Command="{Binding StopSessionCommand}"
                            Background="#C62828" Foreground="White" FontWeight="Bold"
                            Width="110" Height="28" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SessionStatusText}" FontFamily="Consolas" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SessionMarketsEntered, StringFormat='Markets: {0}'}"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
